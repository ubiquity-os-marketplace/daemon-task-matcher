{
  "name": "plugin-template",
  "short_name": "ubiquity-os-marketplace/daemon-task-matcher@development",
  "description": "Ubiquibot plugin template repository with TypeScript support.",
  "ubiquity:listeners": [
    "pull_request.opened",
    "pull_request.reopened",
    "issue_comment.edited"
  ],
  "skipBotEvents": true,
  "configuration": {
    "default": {},
    "type": "object",
    "properties": {
      "confidenceThreshold": {
        "default": 0.8,
        "minimum": 0,
        "maximum": 1,
        "type": "number"
      },
      "maxSuggestions": {
        "default": 5,
        "minimum": 1,
        "maximum": 20,
        "type": "integer"
      },
      "requirePriceLabel": {
        "default": true,
        "type": "boolean"
      },
      "maxIssuesPerLlmCall": {
        "default": 20,
        "minimum": 5,
        "maximum": 200,
        "type": "integer"
      },
      "openRouter": {
        "type": "object",
        "properties": {
          "endpoint": {
            "minLength": 1,
            "type": "string"
          },
          "model": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "endpoint",
          "model"
        ]
      }
    }
  }
}